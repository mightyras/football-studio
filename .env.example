# Supabase configuration
# Get these from your Supabase project: https://supabase.com/dashboard
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sentry error tracking
# DSN is safe for client bundles (public URL)
# Get this from your Sentry project: https://sentry.io
VITE_SENTRY_DSN=

# Build-time only (NOT prefixed with VITE_)
# Used by @sentry/vite-plugin to upload source maps
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
